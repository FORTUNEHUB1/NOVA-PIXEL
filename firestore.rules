rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "kemboifortune98@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorName', 'authorId', 'isPublished', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 500
        && data.content is string && data.content.size() <= 100000
        && data.authorName is string && data.authorName.size() <= 100
        && data.authorId is string && data.authorId == request.auth.uid
        && data.isPublished is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        // Optional fields
        && (!('excerpt' in data) || (data.excerpt is string && data.excerpt.size() <= 1000))
        && (!('featuredImage' in data) || (data.featuredImage is string && data.featuredImage.size() <= 5000000))
        && (!('category' in data) || (data.category is string && data.category.size() <= 100))
        && (!('tags' in data) || (data.tags is list && data.tags.size() <= 20))
        && (!('publishedAt' in data) || data.publishedAt is timestamp);
    }

    match /blogPosts/{postId} {
      // Anyone can read blog posts
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
  }
}
